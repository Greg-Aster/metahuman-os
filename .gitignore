# ============================================
.astro/
.turbo/
*.tsbuildinfo
dist/
build/

# Mobile build artifacts (large binary files - regenerate with build-mobile.sh)
apps/mobile/android/app/libs/
apps/mobile/android/app/src/main/assets/
apps/mobile/www/
apps/mobile/releases/
*mobile-build-backup*

# APK downloads (built artifacts, too large for git)
apps/site/public/downloads/*.apk

# React Native build artifacts
apps/react-native/node_modules/
apps/react-native/android/app/debug.keystore
apps/react-native/android/app/build/
apps/react-native/android/app/src/main/assets/index.android.bundle
apps/react-native/android/app/src/main/assets/nodejs-project/

# React Native nodejs-assets build outputs (generated by build-mobile.sh)
apps/react-native/nodejs-assets/nodejs-project/www/
apps/react-native/nodejs-assets/nodejs-project/.env
apps/react-native/nodejs-assets/nodejs-project/dist/
apps/react-native/android/.gradle/
apps/react-native/android/app/src/main/assets/*.bundle
apps/react-native/ios/Pods/
apps/react-native/ios/build/
apps/react-native/.bundle/
apps/react-native/*.jsbundle

# Capacitor (deprecated - archived to archive/capacitor-mobile branch)
# Ignore if recreated by accidental builds
apps/mobile/

