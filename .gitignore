# ============================================
# PERSONAL DATA - DO NOT COMMIT
# ============================================

# Browser/runtime caches
/data/user-data/
/data/argv.json

# Credentials and local tooling state
/credentials.txt
/.obsidian/
/.claude/
/tmp/
/backups/**/*.tar.gz
/apps/site/logs/

# MULTI-USER PROFILES - All user data is private
/profiles/**
!/profiles/README.md
!/profiles/.gitkeep

# Exclude personal/runtime data from ALL profiles
profiles/*/memory/
profiles/*/state/
profiles/*/training-data/
profiles/*/out/voice-cache/
profiles/*/out/voice-training/
profiles/*/out/adapters/
profiles/*/persona/desires/

# Sensitive config files in profiles (API keys, credentials)
profiles/*/etc/runpod.json
profiles/*/etc/llm-credentials.json
profiles/*/etc/voice.json
profiles/*/etc/*.key
profiles/*/etc/*.pem

# Personal documents at root (trip plans, notes, etc.)
/*_Plan.md
/*_plan.md

# Legacy root-level personal data (for backward compatibility)
/persona/
/persona/users.json
/persona/core.json
/persona/relationships.json
/persona/routines.json
/persona/decision-rules.json
/persona/profile.md
/persona/policy.md
/persona/overrides/**
/persona/capabilities/**

# Personal memories - ALL types
/memory/*
!/memory/README.md

# Personal logs and audit trails
/logs/**
!/logs/README.md

# Personal generated content and outputs
/out/**
!/out/README.md

# Local audit coordination and generated reports
/audit-state.json
/audit-state.json.bak
/docs/audit-scratchpad.md
/report.json
/*.log
/strace*.log
/isolate-*-v8.log

# ============================================
# CONFIGURATION - PERSONAL SETTINGS
# ============================================

# Runtime configuration (contains personal settings)
/etc/agent.json
/etc/audio.json
/etc/boredom.json
/etc/sleep.json
/etc/voice.json
/etc/autonomy.json
/etc/auto-approval.json
/etc/ingestor.json
/etc/lifeline.json
/etc/network.json
/etc/logging.json
/etc/runpod.json
/etc/config
/etc/legacy/
# Keep template/example configs
!/etc/*.template
!/etc/README*.md
!/etc/training*.json
!/etc/model_map.json

