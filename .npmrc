# pnpm configuration for MetaHuman OS monorepo
#
# Use a shorter store path to avoid ENAMETOOLONG errors with
# long babel package names (React Native dependencies).
# Linux has a 255-byte filename limit, and the default store path
# (~/.local/share/pnpm/store/v10/) combined with long package names
# can exceed this limit.

store-dir=/tmp/pnpm

# Hoist React Native packages to root for Gradle compatibility
# shamefully-hoist keeps symlinks but hoists deps to root
shamefully-hoist=true
