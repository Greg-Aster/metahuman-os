#!/usr/bin/env bash
#
# Stop Open Interpreter Server
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
LOG_DIR="$ROOT_DIR/logs/run"
PID_FILE="$LOG_DIR/interpreter-server.pid"

if [ ! -f "$PID_FILE" ]; then
    echo "[interpreter] No PID file found - server may not be running"

    # Try to find by port
    PID=$(lsof -ti:4325 2>/dev/null || true)
    if [ -n "$PID" ]; then
        echo "[interpreter] Found process on port 4325 (PID: $PID)"
        echo "[interpreter] Stopping..."
        kill "$PID" 2>/dev/null || true
        echo "[interpreter] Stopped"
    fi
    exit 0
fi

PID=$(cat "$PID_FILE")

if kill -0 "$PID" 2>/dev/null; then
    echo "[interpreter] Stopping server (PID: $PID)..."
    kill "$PID"
    rm -f "$PID_FILE"
    echo "[interpreter] Server stopped"
else
    echo "[interpreter] Server not running (stale PID file)"
    rm -f "$PID_FILE"
fi
