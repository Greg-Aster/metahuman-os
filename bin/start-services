#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SERVER_LOG="$REPO_ROOT/logs/server.log"
LOG_DIR="$REPO_ROOT/logs/run"
MODE="${1:-console}"

mkdir -p "$REPO_ROOT/logs" "$LOG_DIR"

start_task() {
  local name="$1"
  shift
  local log_file="$LOG_DIR/${name}.launcher.log"

  {
    echo "[$(date -Is)] starting $name"
    set +e
    "$@"
    local exit_code=$?
    set -e
    echo "[$(date -Is)] $name launcher exited with code $exit_code"
    exit "$exit_code"
  } >> "$log_file" 2>&1 &
}

should_start_vllm() {
  local config_file="$REPO_ROOT/etc/llm-backend.json"

  if [ ! -f "$config_file" ] || ! command -v node >/dev/null 2>&1; then
    return 1
  fi

  node -e "
const fs = require('fs');
const config = JSON.parse(fs.readFileSync(process.argv[1], 'utf8'));
process.exit(config.activeBackend === 'vllm' && config.vllm?.autoStart ? 0 : 1);
" "$config_file"
}

start_vllm_task() {
  local log_file="$LOG_DIR/vllm.launcher.log"
  local marker_file="$LOG_DIR/vllm.starting"

  if curl --max-time 3 -fsS "http://127.0.0.1:8000/health" >/dev/null 2>&1; then
    echo "vLLM server already running"
    return 0
  fi

  {
    echo "[$(date -Is)] starting vllm"
    date -Is > "$marker_file"
    set +e
    if command -v timeout >/dev/null 2>&1; then
      timeout 300 "$REPO_ROOT/bin/mh" vllm start
    else
      "$REPO_ROOT/bin/mh" vllm start
    fi
    local exit_code=$?
    if curl --max-time 3 -fsS "http://127.0.0.1:8000/health" >/dev/null 2>&1; then
      exit_code=0
    fi
    set -e
    rm -f "$marker_file"
    echo "[$(date -Is)] vllm launcher exited with code $exit_code"
    exit "$exit_code"
  } >> "$log_file" 2>&1 &
}

start_background_services() {
  start_task event-bus "$REPO_ROOT/bin/start-event-bus"
  if should_start_vllm; then
    start_vllm_task
  fi
  start_task agents "$REPO_ROOT/bin/mh" start --no-restart
  start_task cloudflare "$REPO_ROOT/bin/start-cloudflare"
  start_task voice-server "$REPO_ROOT/bin/start-voice-server"
  start_task local-models "$REPO_ROOT/bin/start-local-models"

  echo "Background service launchers started. Logs: $LOG_DIR"
}

if [ "$MODE" = "--background" ]; then
  start_background_services
  exit 0
fi

echo "MetaHuman service console"
echo
echo "Background services are started by ./start.sh."
echo "To trigger them manually, run: ./bin/start-services --background"
echo "To stop everything, run: ./stop.sh"
echo
echo "Tailing server log:"
echo

touch "$SERVER_LOG"
tail -f "$SERVER_LOG"
