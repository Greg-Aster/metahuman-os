#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Starting MetaHuman Services...${NC}"
echo

CLEANUP_IN_PROGRESS=false

cleanup() {
  # Prevent re-entrant cleanup (multiple Ctrl+C)
  if [ "$CLEANUP_IN_PROGRESS" = true ]; then
    echo -e "\n${YELLOW}Cleanup already in progress, please wait...${NC}"
    return
  fi
  CLEANUP_IN_PROGRESS=true

  # Disable trap during cleanup to prevent cascading
  trap '' INT TERM

  echo
  echo -e "${YELLOW}Shutting down MetaHuman services...${NC}"

  # Stop agents with timeout (5 seconds max)
  timeout 5 "$REPO_ROOT/bin/mh" agent stop --all >/dev/null 2>&1 || true

  # Stop other services with timeouts
  timeout 3 "$REPO_ROOT/bin/stop-terminal" >/dev/null 2>&1 || true
  timeout 3 "$REPO_ROOT/bin/stop-local-models" >/dev/null 2>&1 || true
  timeout 5 "$REPO_ROOT/bin/stop-voice-server" >/dev/null 2>&1 || true
  timeout 3 "$REPO_ROOT/bin/stop-event-bus" >/dev/null 2>&1 || true

  echo -e "${GREEN}Services stopped.${NC}"
}

trap cleanup EXIT INT TERM

# Check headless mode before starting agents
RUNTIME_CONFIG="$REPO_ROOT/etc/runtime.json"
if [ -f "$RUNTIME_CONFIG" ]; then
  HEADLESS=$(grep -o '"headless"[[:space:]]*:[[:space:]]*true' "$RUNTIME_CONFIG" || echo "")
  if [ -n "$HEADLESS" ]; then
    echo -e "${YELLOW}Headless mode active - skipping agent startup${NC}"
  else
    echo "Starting agents..."
    "$REPO_ROOT/bin/mh" start --restart 2>&1 || echo -e "${YELLOW}Warning: Failed to start some agents${NC}"
  fi
else
  echo "Starting agents..."
  "$REPO_ROOT/bin/mh" start --restart 2>&1 || echo -e "${YELLOW}Warning: Failed to start some agents${NC}"
fi

# Start Event Bus first (other services depend on it for telemetry)
echo "Starting Event Bus..."
"$REPO_ROOT/bin/start-event-bus" 2>&1 || echo -e "${YELLOW}Warning: Event Bus failed to start${NC}"

# Auto-start Cloudflare tunnel if enabled
echo "Starting Cloudflare tunnel..."
"$REPO_ROOT/bin/start-cloudflare" 2>&1 || true

# Auto-start voice server based on active TTS provider
echo "Starting voice server..."
"$REPO_ROOT/bin/start-voice-server" 2>&1 || true

# Auto-start local model service
echo "Starting local models..."
"$REPO_ROOT/bin/start-local-models" 2>&1 || true

echo
echo -e "${GREEN}All services started.${NC}"
echo "Press Ctrl+C to stop all services."
echo

# Keep the script running (tail server.log to show activity)
tail -f "$REPO_ROOT/logs/server.log" 2>/dev/null || while true; do sleep 3600; done
