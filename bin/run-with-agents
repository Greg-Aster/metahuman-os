#!/usr/bin/env bash

# Simple wrapper that runs a command with cleanup on exit
# Services are now started from the in-app terminal via bin/start-services

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [ $# -eq 0 ]; then
  echo "Usage: run-with-agents <command> [args...]" >&2
  echo "Example: run-with-agents pnpm dev" >&2
  exit 1
fi

cleanup() {
  "$REPO_ROOT/bin/mh" agent stop --all >/dev/null 2>&1 || true
  "$REPO_ROOT/bin/stop-terminal" >/dev/null 2>&1 || true
  "$REPO_ROOT/bin/stop-local-models" >/dev/null 2>&1 || true
  "$REPO_ROOT/bin/stop-voice-server" >/dev/null 2>&1 || true
}

trap cleanup EXIT INT TERM

cd "$REPO_ROOT/apps/site"

echo "Starting dev server..."
echo "(Open Terminal tab in app to start services)"
echo

# Pipe output to log file for in-app terminal to tail
mkdir -p "$REPO_ROOT/logs"
"$@" 2>&1 | tee "$REPO_ROOT/logs/server.log"
