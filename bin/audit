#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BASELINE="$ROOT/logs/audit/baseline.txt"

tracked_files() {
  git -C "$ROOT" ls-files \
    ':!:apps/code-oss/**' \
    ':!:vendor/**' \
    ':!:external/**' \
    ':!:node_modules/**' \
    ':!:logs/**' \
    ':!:out/**' \
    ':!:memory/**' \
    ':!:data/user-data/**' \
    ':!:metahuman-runs/**'
}

hash_cmd() {
  if command -v sha1sum >/dev/null 2>&1; then echo sha1sum; return; fi
  if command -v shasum >/dev/null 2>&1; then echo shasum; return; fi
  echo cksum
}

snapshot() {
  mkdir -p "$ROOT/logs/audit"
  local hasher
  hasher="$(hash_cmd)"
  (
    cd "$ROOT"
    tracked_files | sort | while read -r file; do
      [ -f "$file" ] || continue
      "$hasher" "$file" | sed 's# \./# #'
    done
  ) > "$BASELINE"
  echo "Wrote baseline: $BASELINE"
}

diff_tree() {
  if [ ! -f "$BASELINE" ]; then
    echo "No baseline found. Run: $0 snapshot" >&2
    return 2
  fi

  local hasher current
  hasher="$(hash_cmd)"
  current="$(mktemp)"
  trap 'rm -f "$current" "$current.flist" "$current.glist"' EXIT

  (
    cd "$ROOT"
    tracked_files | sort | while read -r file; do
      [ -f "$file" ] || continue
      "$hasher" "$file" | sed 's# \./# #'
    done
  ) > "$current"

  cut -d ' ' -f2- "$BASELINE" | sort > "$current.flist"
  cut -d ' ' -f2- "$current" | sort > "$current.glist"

  echo "## Added"
  comm -13 "$current.flist" "$current.glist" || true
  echo
  echo "## Removed"
  comm -23 "$current.flist" "$current.glist" || true
  echo
  echo "## Modified"
  comm -12 "$current.flist" "$current.glist" | while read -r file; do
    local baseline_hash current_hash
    baseline_hash="$(grep " $file$" "$BASELINE" | cut -d ' ' -f1 || true)"
    current_hash="$(grep " $file$" "$current" | cut -d ' ' -f1 || true)"
    if [ "$baseline_hash" != "$current_hash" ]; then
      echo "$file"
    fi
  done || true
}

check_policy() {
  echo "## Architecture Guardrail"
  (
    cd "$ROOT"
    pnpm -s exec tsx scripts/check-architecture.ts \
      --baseline "${ARCHITECTURE_BASELINE:-docs/technical/architecture-guardrail-baseline.json}"
  )

  echo
  echo "## Tracked Large Files"
  (
    cd "$ROOT"
    tracked_files | while read -r file; do
      [ -f "$file" ] || continue
      size="$(wc -c < "$file")"
      if [ "$size" -gt 5242880 ]; then
        echo "WARN: Large tracked file: $file"
      fi
    done
  )

  echo
  echo "## Tracked Package Manifests"
  tracked_files | grep 'package\.json$' | sed 's#^#NOTE: Package manifest: #' || true
}

all() {
  mkdir -p "$ROOT/logs/audit"
  local ts report
  ts="$(date +%F-%H%M%S)"
  report="$ROOT/logs/audit/${ts}.md"
  {
    echo "# Audit Report - ${ts}"
    echo
    diff_tree || true
    echo
    check_policy || true
  } > "$report"
  echo "Wrote audit report: $report"
}

case "${1:-help}" in
  snapshot) snapshot ;;
  diff) diff_tree ;;
  check) check_policy ;;
  all) all ;;
  *) echo "Usage: audit {snapshot|diff|check|all}" ;;
esac
