#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

LOG_DIR="$REPO_ROOT/logs/run"
PID_FILE="$LOG_DIR/local-models.pid"

if [ -f "$PID_FILE" ]; then
  PID=$(cat "$PID_FILE")
  if ps -p "$PID" >/dev/null 2>&1; then
    echo "Stopping local model service (PID: $PID)..."
    kill "$PID" 2>/dev/null || true
    sleep 1
    if ps -p "$PID" >/dev/null 2>&1; then
      echo "Force killing..."
      kill -9 "$PID" 2>/dev/null || true
    fi
  fi
  rm -f "$PID_FILE"
  echo "✓ Local model service stopped"
else
  echo "No local model service running"
fi
