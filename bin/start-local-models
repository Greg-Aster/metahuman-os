#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

LOCAL_MODELS_PORT="${LOCAL_MODELS_PORT:-4324}"
LOG_DIR="$REPO_ROOT/logs/run"
PID_FILE="$LOG_DIR/local-models.pid"
CONFIG_FILE="$REPO_ROOT/etc/llm-backend.json"

mkdir -p "$LOG_DIR"

# Check if auto-start is enabled in config
if [ -f "$CONFIG_FILE" ]; then
  AUTO_START=$(grep -o '"autoStart"[[:space:]]*:[[:space:]]*true' "$CONFIG_FILE" | head -1 || echo "")
  ENABLED=$(grep -o '"enabled"[[:space:]]*:[[:space:]]*true' "$CONFIG_FILE" | head -1 || echo "")

  # Check localModels section specifically
  LOCAL_MODELS_SECTION=$(grep -A 10 '"localModels"' "$CONFIG_FILE" || echo "")
  if [ -n "$LOCAL_MODELS_SECTION" ]; then
    AUTO_START=$(echo "$LOCAL_MODELS_SECTION" | grep -o '"autoStart"[[:space:]]*:[[:space:]]*true' | head -1 || echo "")
    ENABLED=$(echo "$LOCAL_MODELS_SECTION" | grep -o '"enabled"[[:space:]]*:[[:space:]]*true' | head -1 || echo "")
  fi

  if [ -z "$AUTO_START" ] || [ -z "$ENABLED" ]; then
    echo "Local model service disabled or autoStart=false in config"
    exit 0
  fi
fi

# Check if service is already running
if [ -f "$PID_FILE" ]; then
  PID=$(cat "$PID_FILE")
  if ps -p "$PID" >/dev/null 2>&1; then
    echo "Local model service already running (PID: $PID)"
    exit 0
  else
    # Stale PID file
    rm -f "$PID_FILE"
  fi
fi

# Check if something else is using the port
if lsof -i ":$LOCAL_MODELS_PORT" >/dev/null 2>&1; then
  echo "Port $LOCAL_MODELS_PORT already in use, assuming service is running"
  exit 0
fi

# Determine models directory (use profile or fallback)
MODELS_DIR="${MODELS_DIR:-$REPO_ROOT/models}"
mkdir -p "$MODELS_DIR"

echo "Starting local model service on port $LOCAL_MODELS_PORT..."

# Check if we have built dist or need to use tsx
SERVICE_DIR="$REPO_ROOT/packages/local-model-service"
if [ -f "$SERVICE_DIR/dist/index.js" ]; then
  # Production mode - use built js
  nohup node "$SERVICE_DIR/dist/index.js" \
    >"$LOG_DIR/local-models.log" 2>&1 &
else
  # Dev mode - use tsx
  nohup npx tsx "$SERVICE_DIR/src/index.ts" \
    >"$LOG_DIR/local-models.log" 2>&1 &
fi

echo $! > "$PID_FILE"

# Export environment for the service
export PORT="$LOCAL_MODELS_PORT"
export HOST="127.0.0.1"
export MODELS_DIR="$MODELS_DIR"
export CONFIG_PATH="$CONFIG_FILE"

# Wait for service to become healthy
echo "Waiting for service to start..."
for i in {1..30}; do
  if curl -s "http://127.0.0.1:$LOCAL_MODELS_PORT/health" >/dev/null 2>&1; then
    echo "✓ Local model service started (PID: $(cat "$PID_FILE"))"
    echo "   Endpoint: http://127.0.0.1:$LOCAL_MODELS_PORT"
    exit 0
  fi
  sleep 1
done

# Check if process is still running
if ps -p "$(cat "$PID_FILE")" >/dev/null 2>&1; then
  echo "⚠ Service started but health check not responding yet"
  echo "   Check logs: $LOG_DIR/local-models.log"
else
  echo "✗ Local model service failed to start"
  echo "   Check logs: $LOG_DIR/local-models.log"
  rm -f "$PID_FILE"
  exit 1
fi
