#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

LOG_DIR="$REPO_ROOT/logs/run"
LOG_FILE="$LOG_DIR/event-bus.log"
PID_FILE="$LOG_DIR/event-bus.pid"
SERVER_SCRIPT="$REPO_ROOT/packages/core/src/infrastructure/event-bus/server.ts"
TSX_BIN="$REPO_ROOT/node_modules/.bin/tsx"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Check if already running
if [ -f "$PID_FILE" ]; then
  PID=$(cat "$PID_FILE")
  if kill -0 "$PID" 2>/dev/null; then
    echo -e "${YELLOW}Event Bus already running (PID: $PID)${NC}"
    exit 0
  else
    # Stale PID file
    rm -f "$PID_FILE"
  fi
fi

# Also check by LISTEN port (ignore client connections to 3100)
if lsof -n -tiTCP:3100 -sTCP:LISTEN >/dev/null 2>&1; then
  echo -e "${YELLOW}Event Bus already running on port 3100${NC}"
  exit 0
fi

# Check server script exists
if [ ! -f "$SERVER_SCRIPT" ]; then
  echo -e "${RED}ERROR: Event bus server script not found at $SERVER_SCRIPT${NC}"
  exit 1
fi

if [ ! -x "$TSX_BIN" ]; then
  echo -e "${RED}ERROR: tsx executable not found at $TSX_BIN${NC}"
  exit 1
fi

# Ensure log directory exists
mkdir -p "$LOG_DIR"

echo -e "${GREEN}Starting Event Bus server...${NC}"

# Start server in background
cd "$REPO_ROOT"
nohup "$TSX_BIN" "$SERVER_SCRIPT" >> "$LOG_FILE" 2>&1 &
SERVER_PID=$!

# Save PID
echo "$SERVER_PID" > "$PID_FILE"

# Wait a moment and verify startup
sleep 2

if kill -0 "$SERVER_PID" 2>/dev/null; then
  # Check health endpoint
  if curl -s -o /dev/null -w "%{http_code}" http://localhost:3100/health | grep -q "200"; then
    echo -e "${GREEN}Event Bus started successfully (PID: $SERVER_PID)${NC}"
    echo "Health: http://localhost:3100/health"
    echo "Log file: $LOG_FILE"
  else
    echo -e "${YELLOW}Event Bus started (PID: $SERVER_PID) but health check pending...${NC}"
    echo "Check log: $LOG_FILE"
  fi
else
  echo -e "${RED}Event Bus failed to start. Check $LOG_FILE for details${NC}"
  tail -n 20 "$LOG_FILE" 2>/dev/null || true
  exit 1
fi
