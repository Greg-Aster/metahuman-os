{
  "activeBackend": "vllm",
  "ollama": {
    "endpoint": "http://localhost:11434",
    "autoStart": false,
    "defaultModel": "qwen3.5:9b"
  },
  "vllm": {
    "endpoint": "http://localhost:8000",
    "autoStart": false,
    "model": "sanskar003/Qwen3.5-9B-AWQ",
    "gpuMemoryUtilization": 0.85,
    "maxModelLen": 4096,
    "tensorParallelSize": 1,
    "dtype": "float16",
    "quantization": "compressed-tensors",
    "enforceEager": true,
    "autoUtilization": false,
    "enableThinking": false,
    "loadFormat": "safetensors",
    "servedModelName": "sanskar003/Qwen3.5-9B-AWQ"
  },
  "localModels": {
    "enabled": true,
    "endpoint": "http://127.0.0.1:4324",
    "autoStart": true,
    "downloadOnWifiOnly": true,
    "embeddings": {
      "model": "qwen3-embedding-0.6b",
      "preloadAtStartup": true
    },
    "llm": {
      "model": "qwen3-1.7b",
      "preloadAtStartup": false
    }
  },
  "$schema": "https://metahuman.dev/schemas/llm-backend.json",
  "version": "1.0.0",
  "description": "LLM backend configuration - controls which local inference engine is used",
  "remote": {
    "provider": "runpod",
    "serverUrl": "https://mh.dndiy.org",
    "model": ""
  }
}
