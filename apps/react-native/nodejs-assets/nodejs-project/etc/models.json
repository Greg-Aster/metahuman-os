  "cognitiveModeMappings": {
    "dual": {
      "orchestrator": "default.orchestrator",
      "persona": "default.orchestrator",
      "planner": "default.orchestrator",
      "coder": "default.coder",
      "curator": "default.coder",
      "summarizer": "default.orchestrator",
