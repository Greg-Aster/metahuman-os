{
  "$schema": "https://metahuman.dev/schemas/models.json",
  "version": "1.0.0",
  "_WARNING": "═══════════════════════════════════════════════════════════════════════════════",
  "_WARNING2": "██ SYSTEM DEFAULT FILE - DO NOT USE FOR INDIVIDUAL USERS                     ██",
  "_WARNING3": "██                                                                           ██",
  "_WARNING4": "██ User configs are resolved via: getProfilePaths(username) / storageClient ██",
  "_WARNING5": "██ This file is ONLY used to INITIALIZE NEW USER profiles (one-time copy)   ██",
  "_WARNING6": "██ NEVER fall back to this file for existing users at runtime               ██",
  "_WARNING7": "██                                                                           ██",
  "_WARNING8": "██ Code that reads this file for users INSTEAD of their profile is BROKEN   ██",
  "_WARNING9": "═══════════════════════════════════════════════════════════════════════════════",
  "description": "SYSTEM DEFAULT - Used ONLY for new user initialization. See profile-based models.json",
  "globalSettings": {
    "includePersonaSummary": false,
    "useAdapter": false,
    "activeAdapter": null
  },
  "defaults": {
    "orchestrator": "default.orchestrator",
    "persona": "default.persona",
    "curator": "default.curator",
    "coder": "default.coder",
    "planner": "default.planner",
    "summarizer": "default.summarizer",
    "psychotherapist": "default.psychotherapist",
    "fallback": "default.fallback",
    "embedder": "default.embedder"
  },
  "models": {
    "default.orchestrator": {
      "provider": "ollama",
      "model": "qwen3.5:9b",
      "adapters": [],
      "roles": [
        "orchestrator",
        "router",
        "planner",
        "persona",
        "curator",
        "psychotherapist",
        "summarizer"
      ],
      "description": "Capable orchestrator using same model as persona for better intent routing",
      "options": {
        "contextWindow": 8192,
        "temperature": 0.1,
        "topP": 0.9,
        "repeatPenalty": 1.1
      },
      "metadata": {
        "priority": "high",
        "alwaysLoaded": true,
        "estimatedLatency": "fast",
        "sizeGB": 6.6,
        "purpose": "Executive function - intelligent intent routing and tool selection"
      }
    },
    "default.persona": {
      "provider": "ollama",
      "model": "qwen3.5:9b",
      "adapters": [],
      "roles": [
        "persona",
        "conversation",
        "introspection"
      ],
      "description": "Default persona model for conversational responses",
      "options": {
        "contextWindow": 8192,
        "temperature": 0.8,
        "topP": 0.95,
        "repeatPenalty": 1.4
      },
      "metadata": {
        "priority": "high",
        "alwaysLoaded": true,
        "estimatedLatency": "fast",
        "sizeGB": 6.6
      }
    },
    "default.curator": {
      "provider": "ollama",
      "model": "qwen3.5:9b",
      "adapters": [],
      "roles": [
        "curator",
        "summarizer",
        "memory-prep"
      ],
      "description": "Mid-size curator model for memory curation and training data preparation",
      "options": {
        "contextWindow": 8192,
        "temperature": 0.3,
        "topP": 0.9,
        "repeatPenalty": 1.1
      },
      "metadata": {
        "priority": "medium",
        "alwaysLoaded": false,
        "estimatedLatency": "fast",
        "sizeGB": 6.6,
        "purpose": "Memory curation - clean data extraction and training prep"
      }
    },
    "default.coder": {
      "provider": "ollama",
      "model": "qwen3.5:9b",
      "adapters": [],
      "roles": [
        "coder",
        "code-generation",
        "code-review",
        "orchestrator",
        "persona",
        "curator",
        "psychotherapist"
      ],
      "description": "Specialized model for code generation, review, and refactoring",
      "options": {
        "contextWindow": 8192,
        "temperature": 0.2,
        "topP": 0.95,
        "repeatPenalty": 1.1
      },
      "metadata": {
        "priority": "medium",
        "alwaysLoaded": false,
        "estimatedLatency": "fast",
        "sizeGB": 6.6,
        "purpose": "Code specialist - generation, review, debugging, refactoring",
        "specialization": "code"
      }
    },
    "default.planner": {
      "provider": "ollama",
      "model": "qwen3.5:9b",
      "adapters": [],
      "roles": [
        "planner",
        "strategist",
        "task-breakdown"
      ],
      "description": "Strategic planning and task decomposition specialist",
      "options": {
        "contextWindow": 8192,
        "temperature": 0.4,
        "topP": 0.9,
        "repeatPenalty": 1.2
      },
      "metadata": {
        "priority": "medium",
        "alwaysLoaded": false,
        "estimatedLatency": "fast",
        "sizeGB": 6.6,
        "purpose": "Planning specialist - strategic thinking, task breakdown, roadmap creation",
        "specialization": "planning"
      }
    },
    "default.summarizer": {
      "provider": "ollama",
      "model": "qwen3.5:9b",
      "adapters": [],
      "roles": [
        "summarizer",
        "digest",
        "condensation"
      ],
      "description": "Document and conversation summarization specialist",
      "options": {
        "contextWindow": 8192,
        "temperature": 0.3,
        "topP": 0.9,
        "repeatPenalty": 1.1
      },
      "metadata": {
        "priority": "medium",
        "alwaysLoaded": false,
        "estimatedLatency": "fast",
        "sizeGB": 6.6,
        "purpose": "Summarization specialist - condensing documents, extracting key points",
        "specialization": "summarization"
      }
    },
    "default.fallback": {
      "provider": "ollama",
      "model": "qwen3.5:9b",
      "adapters": [],
      "roles": [
        "fallback",
        "general"
      ],
      "description": "Fallback model when primary models unavailable",
      "options": {
        "contextWindow": 8192,
        "temperature": 0.7,
        "topP": 0.9
      },
      "metadata": {
        "priority": "low",
        "alwaysLoaded": true,
        "estimatedLatency": "fast",
        "sizeGB": 6.6
      }
    },
    "default.psychotherapist": {
      "provider": "ollama",
      "model": "qwen3.5:9b",
      "adapters": [],
      "roles": [
        "psychotherapist",
        "interviewer",
        "analyzer"
      ],
      "description": "Specialized interviewer for persona analysis using motivational interviewing techniques",
      "options": {
        "contextWindow": 8192,
        "temperature": 0.7,
        "topP": 0.9,
        "repeatPenalty": 1.1
      },
      "metadata": {
        "priority": "medium",
        "alwaysLoaded": false,
        "estimatedLatency": "medium",
        "sizeGB": 6.6,
        "purpose": "Persona generation and psychological analysis"
      }
    },
    "ollama.qwen3:30b": {
      "provider": "ollama",
      "model": "qwen3:30b",
      "roles": [
        "psychotherapist",
        "orchestrator",
        "persona",
        "curator"
      ],
      "adapters": [],
      "description": "Imported from Ollama tag qwen3:30b",
      "options": {
        "contextWindow": 8192,
        "temperature": 0.7,
        "topP": 0.95,
        "repeatPenalty": 1.5
      },
      "metadata": {
        "source": "ollama-discovery"
      }
    },
    "ollama.gpt-oss:latest": {
      "provider": "ollama",
      "model": "gpt-oss:latest",
      "roles": [
        "orchestrator",
        "persona"
      ],
      "adapters": [],
      "description": "Imported from Ollama tag gpt-oss:latest",
      "options": {},
      "metadata": {
        "source": "ollama-discovery"
      }
    },
    "ollama.qwen3:0.6b": {
      "provider": "ollama",
      "model": "qwen3:0.6b",
      "roles": [
        "orchestrator"
      ],
      "adapters": [],
      "description": "Imported from Ollama tag qwen3:0.6b",
      "options": {},
