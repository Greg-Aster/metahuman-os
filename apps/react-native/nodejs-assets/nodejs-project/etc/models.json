  "providers": {
    "ollama": {
      "baseUrl": "http://localhost:11434",
      "timeout": 120000,
      "retries": 2
    },
    "openai": {
      "baseUrl": "https://api.openai.com/v1",
      "timeout": 60000,
      "retries": 3
    },
    "runpod_serverless": {
      "baseUrl": "https://api.runpod.ai/v2",
      "timeout": 120000,
      "retries": 2
    },
    "claude-code": {
      "baseUrl": "local",
      "timeout": 300000,
      "retries": 1
    }
