    ],
    "curator": [
      "default.curator",
      "default.fallback"
    ],
    "coder": [
      "default.coder",
      "default.fallback"
    ],
    "planner": [
      "default.planner",
      "default.fallback"
    ],
    "summarizer": [
      "default.summarizer",
      "default.curator",
      "default.fallback"
    ],
    "psychotherapist": [
      "default.psychotherapist",
      "default.persona",
      "default.fallback"
    ],
    "fallback": [
      "default.fallback"
    ],
    "embedder": [
      "default.embedder"
    ]
