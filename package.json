{
	"name": "metahuman",
	"version": "1.0.0",
	"description": "An autonomous digital personality extension operating system that mirrors your identity, memories, goals, and personality—operating 24/7 as a seamless extension of yourself",
	"keywords": [
		"ai",
		"artificial-intelligence",
		"digital-personality",
		"autonomous-agents",
		"memory-system",
		"personal-os",
		"llm",
		"ollama"
	],
	"homepage": "https://github.com/Greg-Aster/metahuman-os#readme",
	"bugs": {
		"url": "https://github.com/Greg-Aster/metahuman-os/issues"
	},
	"license": "MIT",
	"author": {
		"name": "Gregory Aster",
		"url": "https://github.com/Greg-Aster"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Greg-Aster/metahuman-os.git"
	},
	"scripts": {
		"postinstall": "node scripts/postinstall.mjs",
		"validate:graphs": "tsx scripts/validate-graphs.ts",
		"dev": "NODE_OPTIONS='--max-old-space-size=4096' cd apps/site && pnpm dev",
		"build": "pnpm validate:graphs && cd apps/site && pnpm build",
		"start": "cd apps/site && pnpm preview",
		"mobile:dev": "cd apps/mobile && ./scripts/dev.sh",
		"mobile:sync": "cd apps/mobile && npx cap sync",
		"mobile:open": "cd apps/mobile && npx cap open android",
		"studio": "cd apps/code-oss && ./launch.sh",
		"studio:dev": "cd apps/code-oss && ./launch-dev.sh",
		"studio:build": "cd apps/code-oss && ./build.sh",
		"studio:watch": "cd apps/code-oss && bash -c 'source ~/.nvm/nvm.sh && nvm use 22.21.1 && npm run watchd'"
	},
	"dependencies": {
		"dotenv": "^17.2.3",
		"fs-extra": "^11.3.2",
		"node-fetch": "^2.7.0",
		"node-pty": "^1.1.0",
		"tsx": "^4.20.6"
	},
	"packageManager": "pnpm@10.15.1+sha512.34e538c329b5553014ca8e8f4535997f96180a1d0f614339357449935350d924e22f8614682191264ec33d1462ac21561aff97f6bb18065351c162c7e8f6de67",
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"@types/node-fetch": "^2.6.13",
		"esbuild": "^0.27.1"
	}
}
