{
  "$schema": "https://metahuman.dev/schemas/services.json",
  "version": "1.0.0",
  "description": "Persistent service lifecycle configuration",
  "services": {
    "environment-bridge": {
      "id": "environment-bridge",
      "enabled": true,
      "type": "manual",
      "priority": "high",
      "agentPath": "environment-bridge/index.ts",
      "usesLLM": false,
      "startOnSystemBoot": true,
      "autoRestart": true,
      "maxRetries": 3,
      "adapterUrl": "ws://127.0.0.1:8790/environment",
      "graph": "environment",
      "comment": "Generic event-driven environment adapter connection."
    },
    "robot-operator": {
      "id": "robot-operator",
      "enabled": true,
      "type": "manual",
      "priority": "normal",
      "agentPath": "services/robot-operator.ts",
      "usesLLM": false,
      "startOnSystemBoot": true,
      "autoRestart": true,
      "maxRetries": 3,
      "inactivityThreshold": 300,
      "jitterMs": 60000,
      "boredomMovementInactivityThreshold": 600,
      "boredomMovementJitterMs": 120000,
      "maxCycleSteps": 3,
      "graph": "environment",
      "comment": "Robot autonomy controller. Dormant in reactive mode; owns the Robot Observer and Boredom Movement inactivity timers in semi and full modes."
    },
    "maintenance-service": {
      "id": "maintenance-service",
      "enabled": true,
      "type": "manual",
      "priority": "normal",
      "agentPath": "services/maintenance-service.ts",
      "usesLLM": false,
      "startOnSystemBoot": true,
      "autoRestart": true,
      "maxRetries": 3,
      "comment": "Maintenance-only service for stale-lock health checks, audit-log cleanup, and embedding preload."
    }
  }
}
