{
  "$schema": "https://metahuman.dev/schemas/queue.json",
  "version": "2.0.0",
  "description": "Single MetaHuman work coordinator resource and recovery limits",
  "enabled": true,
  "lanes": {
    "local-llm": {
      "description": "Local LLM capacity",
      "maxConcurrent": 1,
      "cooldownMs": 2000
    },
    "vector-index": {
      "description": "Vector index capacity",
      "maxConcurrent": 10,
      "cooldownMs": 0
    },
    "remote-llm": {
      "description": "Remote LLM capacity",
      "maxConcurrent": 5,
      "cooldownMs": 0
    }
  },
  "execution": {
    "staleTaskTimeoutMs": 600000,
    "maxAttempts": 3
  }
}
