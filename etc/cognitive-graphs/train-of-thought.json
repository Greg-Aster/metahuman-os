{
  "version": "1.0",
  "format": "svelte-flow",
  "name": "Train of Thought Workflow",
  "description": "Recursive reasoning that follows memory associations, allowing one thought to trigger related thoughts until natural conclusion",
  "cognitiveMode": "agent",
  "last_modified": "2025-12-17",
  "nodes": [
    {
      "id": "1",
      "type": "inputNode",
      "position": {
        "x": 50,
        "y": 200
      },
      "data": {
        "label": "Seed Memory Input",
        "nodeType": "text_input",
        "properties": {
          "inputKey": "seedMemory"
        }
      },
      "width": 180,
      "height": 80
    },
    {
      "id": "2",
      "type": "cognitiveNode",
      "position": {
        "x": 280,
        "y": 200
      },
      "data": {
        "label": "Initialize Scratchpad",
        "nodeType": "scratchpad_initializer",
        "properties": {
          "fields": [
            "thoughts",
            "keywords",
            "seenMemoryIds"
          ]
        }
      },
      "width": 200,
      "height": 80
    },
    {
      "id": "3",
      "type": "cognitiveNode",
      "position": {
        "x": 530,
        "y": 200
      },
      "data": {
        "label": "Generate Thought",
        "nodeType": "thought_generator",
        "properties": {
          "temperature": 0.75,
          "extractKeywords": true,
          "timeout": 300000
        }
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "4",
      "type": "cognitiveNode",
      "position": {
        "x": 800,
        "y": 200
      },
      "data": {
        "label": "Record Thought",
        "nodeType": "scratchpad_updater",
        "properties": {
          "appendTo": "thoughts",
          "trackField": "seenMemoryIds"
        }
      },
      "width": 200,
      "height": 100
    },
    {
      "id": "5",
      "type": "cognitiveNode",
      "position": {
        "x": 1050,
        "y": 200
      },
      "data": {
        "label": "Evaluate: Continue?",
        "nodeType": "thought_evaluator",
        "properties": {
          "minConfidence": 0.4,
          "maxIterations": 7
        }
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "6",
      "type": "cognitiveNode",
      "position": {
        "x": 800,
        "y": 380
      },
      "data": {
        "label": "Search Related Memories",
        "nodeType": "loop_memory_search",
        "properties": {
          "maxResults": 3,
          "excludeSeen": true
        }
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "7",
      "type": "routerNode",
      "position": {
        "x": 1050,
        "y": 380
      },
      "data": {
        "label": "Continue or Exit",
        "nodeType": "conditional_router",
        "properties": {
          "conditionField": "shouldExit"
        }
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "8",
      "type": "cognitiveNode",
      "position": {
        "x": 1350,
        "y": 200
      },
      "data": {
        "label": "Aggregate Thoughts",
        "nodeType": "thought_aggregator",
        "properties": {
          "summaryStyle": "narrative",
          "maxLength": 200,
          "timeout": 300000
        }
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "9",
      "type": "outputNode",
      "position": {
        "x": 1620,
        "y": 200
      },
      "data": {
        "label": "Save Thought Chain",
        "nodeType": "inner_dialogue_capture",
        "properties": {
          "tags": [
            "train-of-thought",
            "reflection",
            "inner"
          ]
        }
      },
      "width": 200,
      "height": 80
    },
    {
      "id": "10",
      "type": "outputNode",
      "position": {
        "x": 1620,
        "y": 320
      },
      "data": {
        "label": "Audit Completion",
        "nodeType": "audit_logger",
        "properties": {
          "category": "decision",
          "event": "train_of_thought_complete"
        }
      },
      "width": 180,
      "height": 60
    }
  ],
