{
  "version": "1.0",
  "format": "svelte-flow",
  "name": "Organizer Agent",
  "description": "Processes unprocessed episodic memories and enriches them with tags and entities using LLM analysis",
  "last_modified": "2025-12-17",
  "nodes": [
    {
      "id": "1",
      "type": "agentNode",
      "position": {
        "x": 100,
        "y": 100
      },
      "data": {
        "label": "memory_loader",
        "nodeType": "memory_loader",
        "properties": {
          "limit": 10,
          "onlyUnprocessed": true
        }
      }
    },
    {
      "id": "2",
      "type": "routerNode",
      "position": {
        "x": 400,
        "y": 100
      },
      "data": {
        "label": "for_each",
        "nodeType": "for_each",
        "properties": {
          "itemName": "memory"
        }
      }
    },
    {
      "id": "3",
      "type": "agentNode",
      "position": {
        "x": 700,
        "y": 100
      },
      "data": {
        "label": "llm_enricher",
        "nodeType": "llm_enricher",
        "properties": {
          "promptTemplate": "Analyze this memory and extract relevant tags and entities.\n\nMemory: {content}\n\nReturn a JSON object with:\n- tags: array of relevant keyword tags (3-7 tags)\n- entities: array of entities mentioned (people, places, things)\n\nFormat: {\"tags\": [...], \"entities\": [...]}"
        }
      }
    },
    {
      "id": "4",
      "type": "agentNode",
      "position": {
        "x": 1000,
        "y": 100
      },
      "data": {
        "label": "memory_saver",
        "nodeType": "memory_saver",
        "properties": {
          "updateOnly": true
        }
      }
    },
    {
      "id": "5",
      "type": "outputNode",
      "position": {
        "x": 1300,
        "y": 100
      },
      "data": {
        "label": "audit_logger",
        "nodeType": "audit_logger",
        "properties": {
          "category": "agent",
          "event": "organizer_memory_processed"
        }
      }
    }
  ],
