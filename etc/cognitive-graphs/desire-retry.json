{
  "version": "1.0",
  "format": "svelte-flow",
  "name": "Desire Retry Loop",
  "description": "Re-plans a desire after outcome review returned 'retry' verdict. Incorporates lessons learned from failed attempt into the new plan.",
  "cognitiveMode": "agent",
  "last_modified": "2025-12-17",
  "nodes": [
    {
      "id": "1",
      "type": "genericNode",
      "position": {
        "x": 100,
        "y": 150
      },
      "data": {
        "label": "Load Desire",
        "nodeType": "desire_loader",
        "properties": {
          "loadById": true
        }
      },
      "width": 200,
      "height": 80
    },
    {
      "id": "2",
      "type": "routerNode",
      "position": {
        "x": 350,
        "y": 150
      },
      "data": {
        "label": "Is Retry Verdict?",
        "nodeType": "conditional",
        "properties": {
          "condition": "desire?.outcomeReview?.verdict === 'retry'"
        }
      },
      "width": 160,
      "height": 80
    },
    {
      "id": "3",
      "type": "genericNode",
      "position": {
        "x": 560,
        "y": 100
      },
      "data": {
        "label": "Add Lessons Learned",
        "nodeType": "desire_enricher",
        "properties": {
          "enrichFromOutcome": true
        }
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "4",
      "type": "genericNode",
      "position": {
        "x": 560,
        "y": 220
      },
      "data": {
        "label": "Build Tool Catalog",
        "nodeType": "tool_catalog_builder",
        "properties": {
          "filterByTrust": true
        }
      },
      "width": 200,
      "height": 80
    },
    {
      "id": "5",
      "type": "genericNode",
      "position": {
        "x": 560,
        "y": 320
      },
      "data": {
        "label": "Load Policies",
        "nodeType": "policy_loader",
        "properties": {
          "include": [
            "decision-rules",
            "hard-rules"
          ]
        }
      },
      "width": 200,
      "height": 80
    },
    {
      "id": "6",
      "type": "genericNode",
      "position": {
        "x": 820,
        "y": 150
      },
      "data": {
        "label": "Generate New Plan",
        "nodeType": "desire_plan_generator",
        "properties": {
          "temperature": 0.3,
          "incorporateLessons": true
        }
      },
      "width": 220,
      "height": 120
    },
    {
      "id": "7",
      "type": "genericNode",
      "position": {
        "x": 1080,
        "y": 150
      },
      "data": {
        "label": "Validate Plan",
        "nodeType": "plan_validator",
        "properties": {
          "checkSkillAvailability": true,
          "checkTrustLevel": true
        }
      },
      "width": 200,
      "height": 100
    },
    {
      "id": "8",
      "type": "agencyNode",
      "position": {
        "x": 1320,
        "y": 150
      },
      "data": {
        "label": "Update with New Plan",
        "nodeType": "desire_updater",
        "properties": {
          "newStatus": "reviewing",
          "incrementPlanVersion": true,
          "archivePreviousPlan": true
        }
      },
      "width": 200,
      "height": 100
    },
    {
      "id": "9",
      "type": "outputNode",
      "position": {
        "x": 1560,
        "y": 150
      },
      "data": {
        "label": "Audit Log",
        "nodeType": "audit_logger",
        "properties": {
          "category": "agency",
          "event": "desire_retry_replan"
        }
      },
      "width": 180,
      "height": 60
    },
    {
      "id": "10",
      "type": "outputNode",
      "position": {
        "x": 350,
        "y": 280
      },
      "data": {
        "label": "Skip (Not Retry)",
        "nodeType": "result_aggregator",
        "properties": {}
      },
      "width": 180,
      "height": 60
    }
  ],
