{
  "version": "1.0",
  "format": "svelte-flow",
  "name": "Outcome Reviewer",
  "description": "Reviews execution outcomes and routes to appropriate next action based on verdict",
  "cognitiveMode": "agent",
  "last_modified": "2025-12-17",
  "nodes": [
    {
      "id": "1",
      "type": "genericNode",
      "position": {
        "x": 100,
        "y": 180
      },
      "data": {
        "label": "Load Executed Desire",
        "nodeType": "desire_loader",
        "properties": {
          "statusFilter": [
            "executing",
            "completed",
            "failed"
          ]
        }
      },
      "width": 200,
      "height": 80
    },
    {
      "id": "2",
      "type": "genericNode",
      "position": {
        "x": 380,
        "y": 180
      },
      "data": {
        "label": "Review Outcome",
        "nodeType": "outcome_reviewer",
        "properties": {
          "temperature": 0.3,
          "evaluateGoalAchievement": true
        }
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "3",
      "type": "genericNode",
      "position": {
        "x": 680,
        "y": 180
      },
      "data": {
        "label": "Route by Verdict",
        "nodeType": "verdict_router",
        "properties": {
          "routes": {
            "completed": 0,
            "continue": 0,
            "retry": 1,
            "escalate": 2,
            "abandon": 0
          }
        }
      },
      "width": 180,
      "height": 120
    },
    {
      "id": "4",
      "type": "agencyNode",
      "position": {
        "x": 950,
        "y": 80
      },
      "data": {
        "label": "Update Final Status",
        "nodeType": "desire_updater",
        "properties": {
          "statusFromVerdict": true,
          "updateOutcomeReview": true,
          "updateMetrics": true
        }
      },
      "width": 200,
      "height": 80
    },
    {
      "id": "5",
      "type": "agencyNode",
      "position": {
        "x": 950,
        "y": 200
      },
      "data": {
        "label": "Loop Back to Planner",
        "nodeType": "desire_updater",
        "properties": {
          "newStatus": "planning",
          "incrementPlanIteration": true,
          "preserveExecutionHistory": true
        }
      },
      "width": 200,
      "height": 80
    },
    {
      "id": "6",
      "type": "genericNode",
      "position": {
        "x": 950,
        "y": 320
      },
      "data": {
        "label": "Escalate to User",
        "nodeType": "approval_queue",
        "properties": {
          "reason": "escalation",
          "notifyUser": true
        }
      },
      "width": 200,
      "height": 80
    },
    {
      "id": "7",
      "type": "genericNode",
      "position": {
        "x": 380,
        "y": 330
      },
      "data": {
        "label": "Record Outcome to Scratchpad",
        "nodeType": "scratchpad_writer",
        "properties": {
          "eventType": "outcome_verdict",
          "includeVerdict": true,
          "includeLessonsLearned": true
        }
      },
      "width": 200,
      "height": 80
    },
    {
      "id": "8",
      "type": "outputNode",
      "position": {
        "x": 1200,
        "y": 200
      },
      "data": {
        "label": "Save to Inner Dialogue",
        "nodeType": "inner_dialogue_capture",
        "properties": {
          "tags": ["agency", "outcome-review", "inner"],
          "dialogueSource": "outcome-reviewer"
