      "data": {
        "type": "object",
        "comment": "Persona data → Persona Formatter"
      }
    },
    {
      "id": "e-7-formatted-3-slot_1",
      "source": "7",
      "target": "3",
      "sourceHandle": "formatted",
      "targetHandle": "slot_1",
      "data": {
        "type": "string",
        "comment": "Formatted persona → Question Generator (for persona voice)"
      }
    },
    {
      "id": "e-3-question-8-text",
      "source": "3",
      "target": "8",
      "sourceHandle": "question",
      "targetHandle": "text",
      "data": {
        "type": "string",
        "comment": "Generated question → Inner Dialogue (purple color)"
      }
    },
    {
      "id": "e-3-question-9-conversation",
      "source": "3",
      "target": "9",
      "sourceHandle": "question",
      "targetHandle": "conversation",
      "data": {
