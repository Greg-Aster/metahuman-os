{
  "version": "1.0",
  "format": "svelte-flow",
  "name": "Curiosity Service Workflow",
  "description": "Generates curiosity questions from weighted memory sampling with user privacy isolation",
  "cognitiveMode": "agent",
  "last_modified": "2025-12-17",
  "nodes": [
    {
      "id": "1",
      "type": "cognitiveNode",
      "position": {
        "x": 100,
        "y": 100
      },
      "data": {
        "label": "Check Question Timing",
        "nodeType": "curiosity_activity_check",
        "properties": {
          "questionIntervalSeconds": 1800
        }
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "2",
      "type": "cognitiveNode",
      "position": {
        "x": 400,
        "y": 100
      },
      "data": {
        "label": "Sample Memories",
        "nodeType": "curiosity_weighted_sampler",
        "properties": {
          "sampleSize": 5,
          "decayFactor": 14
        }
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "3",
      "type": "cognitiveNode",
      "position": {
        "x": 700,
        "y": 100
      },
      "data": {
        "label": "Generate Question",
        "nodeType": "curiosity_question_generator",
        "properties": {
          "temperature": 0.6
        }
      },
      "width": 220,
      "height": 120
    },
    {
      "id": "4",
      "type": "cognitiveNode",
      "position": {
        "x": 1000,
        "y": 100
      },
      "data": {
        "label": "Save Question",
        "nodeType": "curiosity_question_saver",
        "properties": {}
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "5",
      "type": "outputNode",
      "position": {
        "x": 1300,
        "y": 100
      },
      "data": {
        "label": "Audit Completion",
        "nodeType": "audit_logger",
        "properties": {}
      },
      "width": 180,
      "height": 60
    },
    {
      "id": "8",
      "type": "outputNode",
      "position": {
        "x": 1300,
        "y": 220
      },
      "data": {
        "label": "Inner Dialogue",
        "nodeType": "inner_dialogue_capture",
        "schema": {
          "id": "inner_dialogue_capture",
          "name": "Inner Dialogue",
          "category": "output",
          "inputs": [
            { "name": "text", "type": "string", "description": "The content to save as inner dialogue" }
          ],
          "outputs": [
            { "name": "saved", "type": "boolean", "description": "Whether the inner dialogue was saved" }
          ],
          "description": "Saves curiosity questions as inner dialogue (visible in Inner Dialogue tab)",
          "color": "#a855f7",
          "bgColor": "#6b21a8"
        },
        "properties": {
          "tags": ["curiosity", "question", "exploration", "inner"],
          "displayColor": "#a855f7",
          "dialogueSource": "curiosity"
        },
        "title": "Inner Dialogue"
      },
      "width": 220,
      "height": 80
    },
    {
      "id": "6",
      "type": "personaNode",
      "position": {
        "x": 600,
        "y": 0
      },
      "data": {
        "label": "Persona Loader",
        "nodeType": "persona_loader",
        "properties": {}
      },
      "width": 180,
      "height": 60
    },
    {
      "id": "7",
      "type": "personaNode",
      "position": {
        "x": 750,
        "y": 0
      },
      "data": {
        "label": "Persona Formatter",
        "nodeType": "persona_formatter",
        "properties": {
          "includePersonality": true,
          "includeValues": true,
          "includeGoals": true
        }
      },
      "width": 200,
      "height": 80
    },
    {
      "id": "9",
      "type": "outputNode",
      "position": {
        "x": 1300,
        "y": 340
      },
      "data": {
        "label": "TTS Output",
        "nodeType": "tts",
        "properties": {
          "source": "curiosity",
          "defaultMode": "conversation"
        }
      },
      "width": 180,
      "height": 80
    }
