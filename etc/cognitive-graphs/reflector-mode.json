{
  "version": "1.0",
  "format": "svelte-flow",
  "name": "Reflector Agent Workflow",
  "description": "Generates reflections from associative memory chains and saves as inner dialogue",
  "cognitiveMode": "agent",
  "last_modified": "2025-12-31",
  "nodes": [
    {
      "id": "1",
      "type": "llmNode",
      "position": {
        "x": 100,
        "y": 100
      },
      "data": {
        "label": "Generate Reflection",
        "nodeType": "reflector_llm",
        "properties": {
          "role": "persona",
          "temperature": 0.8,
          "timeout": 300000
        }
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "10",
      "type": "outputNode",
      "position": {
        "x": 400,
        "y": 100
      },
      "data": {
        "label": "Thinking Stripper",
        "nodeType": "thinking_stripper",
        "schema": {
          "id": "thinking_stripper",
          "name": "Thinking Stripper",
          "category": "output",
          "inputs": [
            {
              "name": "response",
              "type": "any",
              "description": "LLM response that may contain <think> blocks"
            }
          ],
          "outputs": [
            {
              "name": "response",
              "type": "string",
              "description": "Response with thinking stripped (alias for stripped)"
            },
            {
              "name": "stripped",
              "type": "string",
              "description": "Response with <think> blocks removed"
            },
            {
              "name": "thinking",
              "type": "string",
              "description": "Extracted thinking content (null if none)"
            },
            {
              "name": "hadThinking",
              "type": "boolean",
              "description": "Whether response contained thinking"
            }
          ],
          "properties": {},
          "description": "Extracts <think> blocks for UI display, provides stripped content for memory/TTS",
          "color": "#ef4444",
          "bgColor": "#991b1b"
        },
        "properties": {}
      },
      "width": 180,
      "height": 60
    },
    {
      "id": "2",
      "type": "outputNode",
      "position": {
        "x": 700,
        "y": 100
      },
      "data": {
        "label": "Save Reflection",
        "nodeType": "inner_dialogue_capture",
        "properties": {
          "tags": [
            "idle-thought",
            "self-reflection",
            "inner"
          ],
          "displayColor": "#eab308",
          "dialogueSource": "reflector"
        }
      },
      "width": 220,
      "height": 80
    },
    {
      "id": "7",
      "type": "outputNode",
      "position": {
        "x": 700,
        "y": 100
      },
      "data": {
        "label": "Audit Reflection",
        "nodeType": "audit_logger",
        "properties": {}
      },
      "width": 180,
      "height": 60
    },
    {
      "id": "8",
      "type": "outputNode",
      "position": {
        "x": 700,
        "y": 200
      },
      "data": {
        "label": "TTS Output",
        "nodeType": "tts",
        "properties": {
          "source": "reflector",
          "defaultMode": "inner"
        }
      },
      "width": 180,
      "height": 80
    },
    {
      "id": "11",
      "type": "outputNode",
      "position": {
        "x": 700,
        "y": 300
      },
      "data": {
        "label": "Save Reasoning",
        "nodeType": "reasoning_capture",
        "properties": {
          "dialogueSource": "reflector",
          "displayColor": "#8b5cf6"
        }
      },
      "width": 180,
      "height": 60
    }
  ],
  "edges": [
    {
      "id": "e-1-response-10-response",
      "source": "1",
      "target": "10",
      "sourceHandle": "response",
      "targetHandle": "response",
      "data": {
        "type": "string",
        "comment": "LLM Response → Thinking Stripper (extract <think> blocks)"
      }
    },
    {
      "id": "e-10-stripped-11-passthrough",
      "source": "10",
      "target": "11",
      "sourceHandle": "stripped",
      "targetHandle": "passthrough",
      "data": {
        "type": "string",
        "comment": "Stripped Reflection → Reasoning Capture (passthrough, ensures reasoning saves first)"
      }
    },
    {
      "id": "e-11-passthrough-2-text",
      "source": "11",
      "target": "2",
      "sourceHandle": "passthrough",
      "targetHandle": "text",
      "data": {
        "type": "string",
        "comment": "Reflection from Reasoning Capture → Save Reflection (after reasoning saved)"
      }
    },
    {
      "id": "e-10-stripped-7-eventType",
      "source": "10",
      "target": "7",
      "sourceHandle": "stripped",
      "targetHandle": "eventType",
      "data": {
        "type": "string",
        "comment": "Stripped Reflection → Audit Logger"
      }
    },
    {
      "id": "e-10-stripped-8-innerDialogue",
      "source": "10",
      "target": "8",
      "sourceHandle": "stripped",
      "targetHandle": "innerDialogue",
      "data": {
        "type": "string",
        "comment": "Stripped Reflection → TTS Output (speaks clean content)"
      }
    },
    {
      "id": "e-10-thinking-11-thinking",
      "source": "10",
      "target": "11",
      "sourceHandle": "thinking",
      "targetHandle": "thinking",
      "data": {
        "type": "string",
        "comment": "Extracted Thinking → Save Reasoning (displays in separate section)"
      }
    }
  ]
}