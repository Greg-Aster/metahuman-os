{
  "version": "1.0",
  "format": "svelte-flow",
  "name": "Proactive Desire Generator",
  "description": "Analyzes recent user memories to detect implicit desires. Runs periodically to find patterns and goals the user hasn't explicitly stated.",
  "cognitiveMode": "agent",
  "last_modified": "2025-12-17",
  "nodes": [
    {
      "id": "1",
      "type": "agencyNode",
      "position": {
        "x": 100,
        "y": 150
      },
      "data": {
        "label": "Load Unanalyzed Memories",
        "nodeType": "desire_memory_analyzer",
        "properties": {
          "limit": 20,
          "daysBack": 7,
          "markAsAnalyzed": true
        }
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "2",
      "type": "agencyNode",
      "position": {
        "x": 380,
        "y": 150
      },
      "data": {
        "label": "Detect Desires from Memories",
        "nodeType": "desire_detector",
        "properties": {
          "detectExplicit": true,
          "detectImplicit": true,
          "minConfidence": 0.75
        }
      },
      "width": 220,
      "height": 100
    },
    {
      "id": "3",
      "type": "routerNode",
      "position": {
        "x": 650,
        "y": 150
      },
      "data": {
        "label": "Desire Detected?",
        "nodeType": "conditional",
        "properties": {
          "condition": "detected === true"
        }
      },
      "width": 160,
      "height": 80
    },
    {
      "id": "4",
      "type": "agencyNode",
      "position": {
        "x": 860,
        "y": 100
      },
      "data": {
        "label": "Create Desire Folder",
        "nodeType": "desire_folder_creator",
        "properties": {
          "createScratchpad": true,
          "createManifest": true
        }
      },
      "width": 200,
      "height": 100
    },
    {
      "id": "5",
      "type": "agencyNode",
      "position": {
        "x": 1100,
        "y": 100
      },
      "data": {
        "label": "Set Initial Status",
        "nodeType": "desire_updater",
        "properties": {
          "newStatus": "nascent"
        }
      },
      "width": 200,
      "height": 80
    },
    {
      "id": "6",
      "type": "outputNode",
      "position": {
        "x": 1100,
        "y": 220
      },
      "data": {
        "label": "Audit Log",
        "nodeType": "audit_logger",
        "properties": {
          "category": "agency",
          "event": "proactive_desire_created"
        }
      },
      "width": 180,
      "height": 60
    },
    {
      "id": "7",
      "type": "outputNode",
      "position": {
        "x": 860,
        "y": 250
      },
      "data": {
        "label": "Skip (No Desire)",
        "nodeType": "result_aggregator",
        "properties": {}
      },
      "width": 180,
      "height": 60
    }
  ],
  "edges": [
    {
      "id": "e-1-memories-2-userInput",
      "source": "1",
      "target": "2",
      "sourceHandle": "memories",
      "targetHandle": "userInput",
      "data": {
        "type": "array",
        "comment": "Memories → Desire Detector"
      }
    },
    {
      "id": "e-2-detected-3-value",
      "source": "2",
      "target": "3",
      "sourceHandle": "detected",
      "targetHandle": "value",
      "data": {
        "type": "boolean",
        "comment": "Detection Result → Conditional"
      }
    },
    {
      "id": "e-3-ifTrue-4-desire",
      "source": "3",
      "target": "4",
      "sourceHandle": "ifTrue",
      "targetHandle": "desire",
      "data": {
        "type": "object",
        "comment": "If Detected → Create Folder"
      }
    },
    {
      "id": "e-2-desire-4-desire",
      "source": "2",
      "target": "4",
      "sourceHandle": "desire",
      "targetHandle": "desire",
      "data": {
        "type": "object",
        "comment": "Desire Data → Folder Creator"
      }
    },
    {
      "id": "e-4-desire-5-desire",
      "source": "4",
      "target": "5",
      "sourceHandle": "desire",
      "targetHandle": "desire",
      "data": {
        "type": "object",
        "comment": "Desire → Status Updater"
      }
    },
    {
      "id": "e-5-desire-6-eventType",
      "source": "5",
      "target": "6",
      "sourceHandle": "desire",
      "targetHandle": "eventType",
      "data": {
        "type": "object",
        "comment": "Updated Desire → Audit"
      }
    },
    {
      "id": "e-3-ifFalse-7-input",
      "source": "3",
      "target": "7",
      "sourceHandle": "ifFalse",
      "targetHandle": "input",
      "data": {
        "type": "object",
        "comment": "If Not Detected → Skip"
      }
    }
  ]
}