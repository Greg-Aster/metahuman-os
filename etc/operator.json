{
  "_TEMPLATE_WARNING": "══════════════════════════════════════════════════════════════════════════",
  "_TEMPLATE_WARNING2": "██ THIS IS A SYSTEM TEMPLATE - DO NOT USE DIRECTLY FOR INDIVIDUAL USERS ██",
  "_TEMPLATE_WARNING3": "██ This file is COPIED to user profiles, then the user's copy is used   ██",
  "_TEMPLATE_WARNING4": "══════════════════════════════════════════════════════════════════════════",
  "version": "2.0",
  "scratchpad": {
    "maxSteps": 10,
    "trimToLastN": 10,
    "enableVerbatimMode": true,
    "enableErrorRetry": true
  },
  "models": {
    "useSingleModel": false,
    "planningModel": "default.coder",
    "responseModel": "persona"
  },
  "logging": {
    "enableScratchpadDump": false,
    "logDirectory": "logs/run/agents",
    "verboseErrors": true
  },
  "performance": {
    "cacheCatalog": true,
    "catalogTTL": 60000,
    "parallelSkillExecution": false
  },
  "graphExecutor": {
    "defaultNodeTimeout": 600000,
    "llmNodeTimeout": 900000
  },
  "bigBrotherMode": {
    "enabled": true,
    "provider": "codex",
    "delegateAll": true,
    "escalateOnStuck": true,
    "escalateOnRepeatedFailures": true,
    "maxRetries": 1,
    "includeFullScratchpad": true,
    "autoApplySuggestions": false,
    "executionTimeout": 600000
  },
  "bigBrotherReviewer": {
    "enabled": true,
    "periodicReviewInterval": 50,
    "triggerOnErrors": true,
    "errorThreshold": 3,
    "triggerOnStuck": true,
    "stuckThreshold": 10,
    "allowScratchpadModification": true,
    "allowConfigModification": true,
    "allowCoderAgentTrigger": true,
    "logRetentionDays": 7
  },
  "humanInTheLoop": {
    "enabled": true,
    "requireApproval": true,
    "proposalExpiry": 86400000,
    "showPostExecutionFeedback": true,
    "feedbackBackend": {
      "provider": "memory",
      "availableProviders": ["memory", "big-brother", "runpod", "system-coder"],
      "escalateRejections": true,
      "escalateNegativeFeedback": true,
      "escalationThreshold": 3
    },
    "approvalByTrustLevel": {
      "observe": "block",
      "suggest": "require",
      "supervised_auto": "low_risk_auto",
      "bounded_auto": "medium_risk_auto",
      "adaptive_auto": "auto_with_feedback"
    }
  }
}
